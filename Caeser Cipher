()#splits strings into individual words\n","    finalmessage = []#creates an empty list for the encoded words\n","    for word in string1: #loops for each word in the string\n","      word3 = ''#creates an empty string to add the encoded letters to\n","      for x in word:#loops for every letter in the word\n","        y = x#stores what letter is in each word in a variable\n","        for i in range(shift2):#loops this code the amount of times as the shift\n","          y = shift1(y)#changes the letter to the next one in the alphabet\n","        word3 += y#adds the encoded letter to the encoded word\n","      finalmessage.append(word3)#adds the word to the list of encoded words\n","    string3 = \" \".join(finalmessage)#loins the list into a string again\n","    return string3\n","\n","def decode(string, shift):#same function as above, except the shift is negative this time\n","    string2 = string.lower()\n","    shift2 = 26 - shift\n","    string1 = string2.split()\n","    finalmessage = []\n","    for word in string1:\n","      word3 = ''\n","      for x in word:\n","        y = x\n","        for i in range(shift2):\n","          y = shift1(y)\n","        word3 += y\n","      finalmessage.append(word3)\n","    string3 = \" \".join(finalmessage)\n","    return string3\n","\n","string = input(\"Please type the string to encode or decode\\n\")\n","while True:\n","  try:\n","    shift = int(input(\"please give me the shift\\n\"))\n","    break\n","  except ValueError:\n","    print('That is not a number')#checks if you put a number for the shift value, and makes you do it again if you dont\n","encodedecode = int(input(\"press 1 for encoding or 2 for decoding\\n\"))\n","if encodedecode == 1:\n","  result = encode(string, shift)\n","  print(result)\n","else:\n","  result1 = decode(string, shift)\n","  print(result1)\n"]}]}