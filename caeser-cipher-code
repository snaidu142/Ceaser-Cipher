def encode(string, shift):
    string2 = string.lower()#makes the string lowercase
    shift2 = 26 + shift#adds 26 to the shift to allow negatives
    string1 = string2.split()#splits strings into individual words
    finalmessage = []#creates an empty list for the encoded words
    for word in string1: #loops for each word in the string
      word3 = ''#creates an empty string to add the encoded letters to
      for x in word:#loops for every letter in the word
        y = x#stores what letter is in each word in a variable
        for i in range(shift2):#loops this code the amount of times as the shift
          y = shift1(y)#changes the letter to the next one in the alphabet
        word3 += y#adds the encoded letter to the encoded word
      finalmessage.append(word3)#adds the word to the list of encoded words
    string3 = " ".join(finalmessage)#loins the list into a string again
    return string3

def decode(string, shift):#same function as above, except the shift is negative this time
    string2 = string.lower()
    shift2 = 26 - shift
    string1 = string2.split()
    finalmessage = []
    for word in string1:
      word3 = ''
      for x in word:
        y = x
        for i in range(shift2):
          y = shift1(y)
        word3 += y
      finalmessage.append(word3)
    string3 = " ".join(finalmessage)
    return string3

